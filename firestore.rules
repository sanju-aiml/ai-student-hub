rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default-deny catch-all rule
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation blueprints
    function isValidStreak(data) {
      return data.userId is string 
        && data.userId.size() <= 128
        && data.streakCount is int 
        && data.streakCount >= 0 
        && data.lastCheckInDate is string 
        && data.lastCheckInDate.size() == 10
        && data.keys().hasAll(['userId', 'streakCount', 'lastCheckInDate', 'updatedAt'])
        && data.keys().size() == 4;
    }

    // Streaks Collection
    match /streaks/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) 
        && isValidId(userId) 
        && isValidStreak(incoming())
        && incoming().userId == userId;
      allow delete: if false;
    }
  }
}
